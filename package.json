{
  "name": "fcs-mart-bd",
  "private": true,
  "description": "Run npm scripts from repo root; app lives in shopping-app/",
  "scripts": {
    "dev": "npm run dev --prefix shopping-app",
    "dev:full": "npm run dev:full --prefix shopping-app",
    "server:dev": "npm run server:dev --prefix shopping-app",
    "server:dev:watch": "npm run server:dev:watch --prefix shopping-app",
